{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/favoritos/layout,_N_T_/favoritos/page,_N_T_/favoritos"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/favoritos/__PAGE__",
    "/favoritos",
    "/_index",
    "/_head"
  ]
}