# Backend
MONGODB_URI=
JWT_SECRET=
TWO_FACTOR_ENCRYPTION_KEY= # Random 32+ byte string used for AES-256-GCM encryption
PORT=3001

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP / Gmail OAuth2
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_OAUTH_CLIENT_ID=
SMTP_OAUTH_CLIENT_SECRET=
SMTP_OAUTH_REFRESH_TOKEN=

# WhatsApp Meta Cloud API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TEMPLATES_JSON=[{"name":"saludo_inicial_crm","language":"es_AR","category":"MARKETING","label":"Saludo inicial"}]
# Frontend local development
NEXT_PUBLIC_API_URL=http://localhost:3001

# Opcional: Servidores DNS para MongoDB (ej. en Vercel si hay problemas de DNS resolving)
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# Configuración de sembrado de Administrador (scripts/seed-admin.js)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
CONFIRM_PRODUCTION_SEED=false

# Rate Limiting Distribuido (Fase 5 - Opcional, con fallback en memoria)
REDIS_URL=
REDIS_TOKEN=

# Internal Cron Jobs
CRON_SECRET=
